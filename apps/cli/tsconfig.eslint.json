{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node"],
    "noEmit": true,
    "composite": false
  },
  "references": [
    { "path": "../../packages/shared" },
    { "path": "../../packages/config" },
    { "path": "../../packages/engine" },
    { "path": "../../packages/reporter" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}